#include <stdio.h>
#include <string.h>
#include <ctype.h>
int main() {
    char name[50];
    scanf("%[^\n]", name);
    int len = strlen(name);
    int valid = 1;
    if(len < 3 || len > 20) valid = 0;
    if(name[0] == ' ' || name[len-1] == ' ') valid = 0;
    for(int i=0;i<len;i++) if(isdigit(name[i])) valid = 0;
    printf("%s Name\nLength: %d\n", valid ? "Valid" : "Invalid", len);
    return 0;
}
