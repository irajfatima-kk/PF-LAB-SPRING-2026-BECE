#include <stdio.h>

int main() {
    int marks, pass[10], fail[10];
    int i = 0, pCount = 0, fCount = 0;
    float pSum = 0, fSum = 0;

    printf("Enter marks of students (-1 to stop):\n");
    while(i < 10) {
        scanf("%d", &marks);
        if(marks == -1) break;

        if(marks >= 5 && marks <= 10) {
            pass[pCount++] = marks;
            pSum += marks;
        } else if(marks >= 0 && marks < 5) {
            fail[fCount++] = marks;
            fSum += marks;
        }
        i++;
    }

    printf("\nPass students marks: ");
    for(i = 0; i < pCount; i++) {
        printf("%d ", pass[i]);
    }
    if(pCount > 0) printf("\nAverage (Pass): %.2f", pSum/pCount);

    printf("\nFail students marks: ");
    for(i = 0; i < fCount; i++) {
        printf("%d ", fail[i]);
    }
    if(fCount > 0) printf("\nAverage (Fail): %.2f", fSum/fCount);

    return 0;
}
