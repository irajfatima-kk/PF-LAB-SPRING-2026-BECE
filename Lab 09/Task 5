#include <stdio.h>

float toMegajoules(float kwh) { return kwh * 3.6; }
float toBTU(float kwh) { return kwh * 3412.14; }
float toCalories(float kwh) { return kwh * 859845; }

int main() {
    float kwh;
    printf("Enter energy reading (kWh): ");
    scanf("%f", &kwh);

    printf("\n--- Conversion Report ---\n");
    printf("MJ: %.2f\n", toMegajoules(kwh));
    printf("BTU: %.2f\n", toBTU(kwh));
    printf("Calories: %.2f\n", toCalories(kwh));

    // Demonstrating function call chaining
    printf("MJ (direct call): %.2f\n", toMegajoules(kwh));

    return 0;
}
