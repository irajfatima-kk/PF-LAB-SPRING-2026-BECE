#include <stdio.h>

int main() {
    int temp[7][3] = {
        {25, 30, 28},
        {27, 32, 29},
        {26, 31, 30},
        {28, 33, 27},
        {29, 34, 32},
        {30, 35, 31},
        {31, 36, 33}
    };

    int highest = temp[0][0];
    for (int i = 0; i < 7; i++) {
        int sum = 0;
        for (int j = 0; j < 3; j++) {
            if (temp[i][j] > highest) highest = temp[i][j];
            sum += temp[i][j];
        }
        printf("Day %d average = %.2f\n", i+1, sum/3.0);
    }

    printf("Highest temperature = %d\n", highest);
    return 0;
}
