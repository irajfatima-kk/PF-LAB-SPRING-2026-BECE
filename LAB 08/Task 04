#include <stdio.h>


int determinant(int mat[3][3]) {
    int det = mat[0][0]*(mat[1][1]*mat[2][2] - mat[1][2]*mat[2][1])
            - mat[0][1]*(mat[1][0]*mat[2][2] - mat[1][2]*mat[2][0])
            + mat[0][2]*(mat[1][0]*mat[2][1] - mat[1][1]*mat[2][0]);
    return det;
}


void cofactor(int mat[3][3], int cofac[3][3]) {
    cofac[0][0] =  (mat[1][1]*mat[2][2] - mat[1][2]*mat[2][1]);
    cofac[0][1] = -(mat[1][0]*mat[2][2] - mat[1][2]*mat[2][0]);
    cofac[0][2] =  (mat[1][0]*mat[2][1] - mat[1][1]*mat[2][0]);

    cofac[1][0] = -(mat[0][1]*mat[2][2] - mat[0][2]*mat[2][1]);
    cofac[1][1] =  (mat[0][0]*mat[2][2] - mat[0][2]*mat[2][0]);
    cofac[1][2] = -(mat[0][0]*mat[2][1] - mat[0][1]*mat[2][0]);

    cofac[2][0] =  (mat[0][1]*mat[1][2] - mat[0][2]*mat[1][1]);
    cofac[2][1] = -(mat[0][0]*mat[1][2] - mat[0][2]*mat[1][0]);
     cofac[2][2] =  (mat[0][0]*mat[1][1] - mat[0][1]*mat[1][0]);
}


void transpose(int mat[3][3], int trans[3][3]) {
    for(int i=0;i<3;i++) {
        for(int j=0;j<3;j++) {
            trans[i][j] = mat[j][i];
        }
    }
}

int main() {
    int mat[3][3] = {
        {2, -1, 0},
        {1, 2, 1},
        {3, 0, 2}
    };
    printf("Original Matrix:\n");
    for(int i=0;i<3;i++) {
        for(int j=0;j<3;j++) {
            printf("%3d ", mat[i][j]);
        }
        printf("\n");
    }

    
    int trans[3][3];
    transpose(mat, trans);
    printf("\nTranspose:\n");
    for(int i=0;i<3;i++) {
        for(int j=0;j<3;j++) {
            printf("%3d ", trans[i][j]);
        }
        printf("\n");
    }
    
    int det = determinant(mat);
    printf("\nDeterminant = %d\n", det);

    int cofac[3][3];
    cofactor(mat, cofac);
    printf("\nCofactor Matrix:\n");
    for(int i=0;i<3;i++) {
        for(int j=0;j<3;j++) {
            printf("%3d ", cofac[i][j]);
        }
        printf("\n");
    }

    
    int adj[3][3];
    transpose(cofac, adj);
    printf("\nAdjoint Matrix:\n");
    for(int i=0;i<3;i++) {
        for(int j=0;j<3;j++) {
            printf("%3d ", adj[i][j]);
        }
        printf("\n");
    }

   
    if(det != 0) {
        printf("\nInverse Matrix:\n");
        for(int i=0;i<3;i++) {
            for(int j=0;j<3;j++) {
                printf("%6.2f ", adj[i][j]/(float)det);
            }
            printf("\n");
        }
        } else {
        printf("\nMatrix is Singular, no inverse exists.\n");
    }

    return 0;
}
